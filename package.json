{
  "name": "@jream/zodgoose",
  "version": "0.2.3",
  "description": "Bridge Zod schemas to Mongoose — single source of truth, full type inference.",
  "keywords": [
    "mongodb",
    "mongoose",
    "zod"
  ],
  "license": "MIT",
  "author": "Jesse Boyer <hello@jream.com> (https://jream.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/JREAM/zodgoose"
  },
  "homepage": "https://github.com/JREAM/zodgoose",
  "bugs": {
    "url": "https://github.com/JREAM/zodgoose/issues"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build": "tsdown",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "coverage": "bun test --coverage",
    "coverage:check": "c8 --reporter=text-summary --reporter=lcov --all --src=src --lines=100 --functions=100 --statements=100 --branches=95 bun test --coverage",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "c8": "^10.1.0",
    "mongodb-memory-server": "^10.1.2",
    "mongoose-lean-defaults": "^2.3.0",
    "mongoose-lean-getters": "^2.1.0",
    "mongoose-lean-virtuals": "^2.0.0",
    "mongoose-long": "^0.8.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "mongoose": ">=7.0.0",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "mongoose-lean-defaults": {
      "optional": true
    },
    "mongoose-lean-getters": {
      "optional": true
    },
    "mongoose-lean-virtuals": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
